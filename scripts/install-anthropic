#!/usr/bin/env bash
# Convenience wrapper: clone + install fwh_anthropic with per-area extras.
#
# fwh_anthropic covers six Anthropic integration areas (Messages, Batch,
# Files, Agent SDK, Claude Code, Computer Use). Most areas need only the
# anthropic Python SDK (pulled in transitively); two need extra packages
# (`agent_sdk` → claude-agent-sdk, `mcp` → mcp) and one needs the
# `claude` CLI on PATH (the claude_code area).
#
# This script picks the right pip extras based on which areas you want
# and reports what's still missing (e.g. claude CLI, ANTHROPIC_API_KEY).
#
# Usage:
#   scripts/install-anthropic                  # core: anthropic SDK only
#   scripts/install-anthropic --all            # everything: agent_sdk + mcp
#   scripts/install-anthropic --agent-sdk      # core + claude-agent-sdk
#   scripts/install-anthropic --mcp            # core + mcp
#   scripts/install-anthropic --agent-sdk --mcp
#   scripts/install-anthropic --check          # also verify entry-point + env

set -euo pipefail

SCRIPT_DIR="$(cd "$(dirname "$0")" && pwd)"

WANT_AGENT_SDK=false
WANT_MCP=false
CHECK=false
PASS_THROUGH=()

while [[ $# -gt 0 ]]; do
    case "$1" in
        -h|--help)
            cat <<EOF
Usage: scripts/install-anthropic [OPTIONS]

Clone + install fwh_anthropic with optional per-area extras.

Options:
  --all             Install all area extras (agent_sdk + mcp).
  --agent-sdk       Include the claude-agent-sdk extra.
  --mcp             Include the mcp extra.
  --check           Verify entry-point discovery + report env readiness.
  --dir DIR         Forwarded to install-example (clone root).
  --venv DIR        Forwarded to install-example (venv to install into).
  -h, --help        Show this help.

Anything after \`--\` is forwarded verbatim to install-example.
EOF
            exit 0
            ;;
        --all) WANT_AGENT_SDK=true; WANT_MCP=true; shift ;;
        --agent-sdk) WANT_AGENT_SDK=true; shift ;;
        --mcp) WANT_MCP=true; shift ;;
        --check) CHECK=true; shift ;;
        --dir|--venv) PASS_THROUGH+=("$1" "$2"); shift 2 ;;
        --) shift; PASS_THROUGH+=("$@"); break ;;
        *) echo "Unknown option: $1" >&2; exit 2 ;;
    esac
done

EXTRAS=()
$WANT_AGENT_SDK && EXTRAS+=("agent_sdk")
$WANT_MCP && EXTRAS+=("mcp")

CMD=("$SCRIPT_DIR/install-example" "anthropic")
if [[ ${#EXTRAS[@]} -gt 0 ]]; then
    EXTRAS_JOINED="$(IFS=,; echo "${EXTRAS[*]}")"
    CMD+=(--extras "$EXTRAS_JOINED")
fi
$CHECK && CMD+=(--check)
if [[ ${#PASS_THROUGH[@]} -gt 0 ]]; then
    CMD+=("${PASS_THROUGH[@]}")
fi

"${CMD[@]}"

if [[ "$CHECK" == "true" ]]; then
    echo
    echo "==> Environment checks"

    if command -v claude >/dev/null 2>&1; then
        echo "    claude CLI       OK ($(command -v claude))"
    else
        echo "    claude CLI       MISSING — needed for the claude_code area."
        echo "                     Install with: npm install -g @anthropic-ai/claude-code"
    fi

    if [[ -n "${ANTHROPIC_API_KEY:-}" ]]; then
        masked="${ANTHROPIC_API_KEY:0:8}…"
        echo "    ANTHROPIC_API_KEY set ($masked) — live API calls will work"
    else
        echo "    ANTHROPIC_API_KEY not set — set it before live runs:"
        echo "                     export ANTHROPIC_API_KEY=sk-…"
        echo "                     (unit tests + run.py smokes mock the client, no key needed)"
    fi
fi
