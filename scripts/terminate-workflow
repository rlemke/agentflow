#!/usr/bin/env python3
# Terminate a stuck/abandoned workflow by marking its runner, steps, and
# tasks as terminal so the stuck-step sweep stops re-processing it.
#
# Use this for clearly-dead workflows that retry/repair can't recover —
# e.g. a test run that failed at the handler layer (missing API key,
# removed binary) and would otherwise retry forever.
#
# Usage:
#   scripts/terminate-workflow <runner_id> [<runner_id> ...]
#   scripts/terminate-workflow --dry <runner_id>
#   scripts/terminate-workflow --workflow <workflow_name>   # all stuck runners for this workflow
#
# Environment:
#   AFL_MONGODB_URL    MongoDB connection string (default from .env)
"""Terminate a stuck workflow by marking everything terminal."""

from __future__ import annotations

import argparse
import os
import sys
from typing import Any

try:
    from pymongo import MongoClient
except ImportError:
    print("ERROR: pymongo not installed. pip install pymongo", file=sys.stderr)
    sys.exit(1)


STEP_COMPLETE = "state.statement.Complete"
STEP_ERROR = "state.statement.Error"
NON_TERMINAL_STEP_STATES = [
    "state.statement.Created",
    "state.facet.initialization.Begin",
    "state.facet.initialization.End",
    "state.facet.scripts.Begin",
    "state.facet.scripts.End",
    "state.statement.scripts.Begin",
    "state.statement.scripts.End",
    "state.mixin.blocks.Begin",
    "state.mixin.blocks.Continue",
    "state.mixin.blocks.End",
    "state.mixin.capture.Begin",
    "state.mixin.capture.End",
    "state.EventTransmit",
    "state.statement.blocks.Begin",
    "state.statement.blocks.Continue",
    "state.statement.blocks.End",
    "state.block.execution.Begin",
    "state.block.execution.Continue",
    "state.block.execution.End",
    "state.statement.capture.Begin",
    "state.statement.End",
]
NON_TERMINAL_TASK_STATES = ["pending", "running"]


HEARTBEAT_WINDOW_MS = 30_000  # tasks heartbeating within this window are "live"


def live_running_tasks(db: Any, runner_id: str, now_ms: int) -> list[dict[str, Any]]:
    """Return RUNNING tasks for *runner_id* whose handler-level heartbeat
    fired within HEARTBEAT_WINDOW_MS — the operator probably doesn't
    want to terminate a workflow that's actively making progress."""
    horizon = now_ms - HEARTBEAT_WINDOW_MS
    return list(
        db.tasks.find(
            {
                "runner_id": runner_id,
                "state": "running",
                "task_heartbeat": {"$gte": horizon},
            },
            {"uuid": 1, "name": 1, "step_id": 1, "task_heartbeat": 1, "_id": 0},
        )
    )


def terminate_runner(db: Any, runner_id: str, dry: bool) -> dict[str, int]:
    runner = db.runners.find_one({"uuid": runner_id})
    if not runner:
        return {"runner": 0, "steps": 0, "tasks": 0}

    workflow_id = runner.get("workflow_id", "")
    counts = {"runner": 0, "steps": 0, "tasks": 0}

    # Runner state
    if runner.get("state") not in ("completed", "failed"):
        counts["runner"] = 1
        if not dry:
            db.runners.update_one(
                {"uuid": runner_id},
                {"$set": {"state": "failed", "error": "terminated by operator"}},
            )

    # Steps
    step_query: dict[str, Any] = {"state": {"$in": NON_TERMINAL_STEP_STATES}}
    if workflow_id:
        step_query["workflow_id"] = workflow_id
    counts["steps"] = db.steps.count_documents(step_query)
    if counts["steps"] and not dry:
        db.steps.update_many(
            step_query,
            {"$set": {"state": STEP_ERROR, "error": "terminated by operator"}},
        )

    # Tasks
    task_query: dict[str, Any] = {
        "runner_id": runner_id,
        "state": {"$in": NON_TERMINAL_TASK_STATES},
    }
    counts["tasks"] = db.tasks.count_documents(task_query)
    if counts["tasks"] and not dry:
        db.tasks.update_many(
            task_query,
            {"$set": {"state": "canceled", "error": "terminated by operator"}},
        )

    return counts


def runners_for_workflow_name(db: Any, name: str) -> list[str]:
    return [
        r["uuid"]
        for r in db.runners.find(
            {
                "workflow.name": name,
                "state": {"$nin": ["completed", "failed"]},
            },
            {"uuid": 1, "_id": 0},
        )
    ]


def main() -> int:
    parser = argparse.ArgumentParser(
        description="Terminate stuck workflows (runner+steps+tasks → terminal).",
    )
    parser.add_argument("runner_ids", nargs="*", help="Runner UUIDs to terminate.")
    parser.add_argument(
        "--workflow",
        action="append",
        default=[],
        help=(
            "Match every non-terminal runner with this qualified workflow name. "
            "Repeatable."
        ),
    )
    parser.add_argument(
        "--dry", action="store_true", help="Report what would change without writing."
    )
    parser.add_argument(
        "--force",
        action="store_true",
        help=(
            "Terminate even if running tasks have heartbeats within the "
            f"last {HEARTBEAT_WINDOW_MS // 1000}s (i.e. are actively making "
            "progress). Default: refuse and report which tasks look live."
        ),
    )
    args = parser.parse_args()

    mongo_url = os.environ.get("AFL_MONGODB_URL", "mongodb://localhost:27017")
    db_name = os.environ.get("AFL_MONGODB_DATABASE", "facetwork")
    client = MongoClient(mongo_url)
    db = client[db_name]

    ids = list(args.runner_ids)
    for wf in args.workflow:
        ids.extend(runners_for_workflow_name(db, wf))

    if not ids:
        parser.error("No runner_ids given and --workflow matched nothing.")

    # Safety: refuse to terminate runners with tasks actively heartbeating
    # within the last HEARTBEAT_WINDOW_MS. --force overrides.
    if not args.force and not args.dry:
        import time as _time

        now_ms = int(_time.time() * 1000)
        blocked: list[tuple[str, list[dict[str, Any]]]] = []
        for rid in ids:
            live = live_running_tasks(db, rid, now_ms)
            if live:
                blocked.append((rid, live))
        if blocked:
            for rid, tasks in blocked:
                print(
                    f"REFUSED {rid[:12]}: {len(tasks)} task(s) heartbeating within "
                    f"the last {HEARTBEAT_WINDOW_MS // 1000}s:",
                    file=sys.stderr,
                )
                for t in tasks:
                    age = (now_ms - int(t.get("task_heartbeat") or 0)) // 1000
                    print(
                        f"    {t['name']}  step={t['step_id'][:12]}  heartbeat={age}s ago",
                        file=sys.stderr,
                    )
            print(
                "\nRun with --force to terminate anyway, or --dry to preview "
                "without writing.",
                file=sys.stderr,
            )
            return 2

    total = {"runner": 0, "steps": 0, "tasks": 0}
    for rid in ids:
        c = terminate_runner(db, rid, args.dry)
        prefix = "DRY " if args.dry else ""
        print(
            f"{prefix}{rid[:12]}: runner={c['runner']} "
            f"steps→Error={c['steps']} tasks→canceled={c['tasks']}"
        )
        for k in total:
            total[k] += c[k]

    suffix = "would change" if args.dry else "changed"
    print(
        f"\nTotal {suffix}: {total['runner']} runner(s), "
        f"{total['steps']} step(s), {total['tasks']} task(s)"
    )
    return 0


if __name__ == "__main__":
    sys.exit(main())
