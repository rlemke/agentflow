#!/usr/bin/env python3
"""Range-capable HTTP server for PMTiles-backed tiled maps.

Why this exists: Python's stdlib ``http.server`` doesn't support HTTP Range
requests, which the PMTiles client *requires* to fetch byte ranges out of
a single archive file. Serving a tiled map with ``python -m http.server``
silently breaks: the map shell loads, but every PMTiles fetch returns 200
with the whole file and the renderer goes empty.

This server adds a minimal Range handler — parses ``Range: bytes=START-END``,
seeks, returns 206 Partial Content with the right ``Content-Range`` /
``Content-Length`` / ``Accept-Ranges``. CORS is permissive (the browser
fetches via ``location.origin`` so it's all same-origin in practice, but
opening on alternate ports during development trips up some configs).

Usage:
    scripts/serve-tiled-map <port> <dir>
    scripts/serve-tiled-map <dir>                   # default port 8765
    scripts/serve-tiled-map                         # cwd, port 8765
"""
from __future__ import annotations

import argparse
import os
import sys
from http import HTTPStatus
from http.server import BaseHTTPRequestHandler, ThreadingHTTPServer
from pathlib import Path

_MIME = {
    ".html": "text/html; charset=utf-8",
    ".css": "text/css",
    ".js": "application/javascript",
    ".json": "application/json",
    ".pmtiles": "application/octet-stream",
    ".geojson": "application/geo+json",
    ".png": "image/png",
    ".jpg": "image/jpeg",
    ".svg": "image/svg+xml",
}


def _mime(path: Path) -> str:
    return _MIME.get(path.suffix.lower(), "application/octet-stream")


def _parse_range(header: str, size: int) -> tuple[int, int] | None:
    """Parse ``Range: bytes=START-END``. Returns inclusive (start, end) or None."""
    if not header or not header.startswith("bytes="):
        return None
    spec = header[len("bytes=") :]
    if "," in spec:  # multipart ranges — out of scope; fall back to full
        return None
    a, _, b = spec.partition("-")
    try:
        if a == "":
            # Suffix: bytes=-N → last N bytes
            n = int(b)
            return (max(size - n, 0), size - 1)
        start = int(a)
        end = int(b) if b else size - 1
    except ValueError:
        return None
    if start > end or start >= size:
        return None
    end = min(end, size - 1)
    return (start, end)


def _make_handler(root: Path) -> type[BaseHTTPRequestHandler]:
    class _H(BaseHTTPRequestHandler):
        server_version = "facetwork-tiled-map/1.0"

        def log_message(self, fmt: str, *args: object) -> None:  # quieter logs
            sys.stderr.write("%s - %s\n" % (self.address_string(), fmt % args))

        def _resolve(self) -> Path | None:
            # Strip leading "/" and any query
            rel = self.path.lstrip("/").split("?", 1)[0]
            if not rel or rel.endswith("/"):
                rel = (rel + "index.html") if rel else "index.html"
            # Containment check on the URL itself — don't follow symlinks
            # before the check, or symlinks deliberately pointing at the
            # PMTiles cache (e.g. routes.pmtiles → /Users/.../cache/...) get
            # rejected even though they live inside the served dir.
            literal = (root / rel).absolute()
            root_abs = root.absolute()
            try:
                literal.relative_to(root_abs)
            except ValueError:
                return None
            # Resolve any symlink LAST, after we've verified the URL is
            # safely under root.
            target = literal.resolve() if literal.is_symlink() else literal
            return target if target.is_file() else None

        def _send_common(self, status: int, path: Path, content_length: int,
                         content_range: str | None = None) -> None:
            self.send_response(status)
            self.send_header("Content-Type", _mime(path))
            self.send_header("Content-Length", str(content_length))
            self.send_header("Accept-Ranges", "bytes")
            self.send_header("Access-Control-Allow-Origin", "*")
            self.send_header("Cache-Control", "no-cache")
            if content_range:
                self.send_header("Content-Range", content_range)
            self.end_headers()

        def do_HEAD(self) -> None:
            path = self._resolve()
            if path is None:
                self.send_error(HTTPStatus.NOT_FOUND)
                return
            size = path.stat().st_size
            rng = _parse_range(self.headers.get("Range", ""), size)
            if rng is None:
                self._send_common(HTTPStatus.OK, path, size)
            else:
                start, end = rng
                self._send_common(
                    HTTPStatus.PARTIAL_CONTENT, path, end - start + 1,
                    f"bytes {start}-{end}/{size}",
                )

        def do_GET(self) -> None:
            path = self._resolve()
            if path is None:
                self.send_error(HTTPStatus.NOT_FOUND)
                return
            size = path.stat().st_size
            rng = _parse_range(self.headers.get("Range", ""), size)
            try:
                if rng is None:
                    self._send_common(HTTPStatus.OK, path, size)
                    with path.open("rb") as f:
                        self._copy(f, size)
                else:
                    start, end = rng
                    self._send_common(
                        HTTPStatus.PARTIAL_CONTENT, path, end - start + 1,
                        f"bytes {start}-{end}/{size}",
                    )
                    with path.open("rb") as f:
                        f.seek(start)
                        self._copy(f, end - start + 1)
            except (BrokenPipeError, ConnectionResetError):
                # Client closed mid-response — common when a tile request is
                # cancelled (zoom/pan). Quietly drop it.
                pass

        def _copy(self, f, remaining: int, chunk: int = 65536) -> None:
            while remaining > 0:
                data = f.read(min(chunk, remaining))
                if not data:
                    break
                self.wfile.write(data)
                remaining -= len(data)

    return _H


def main() -> int:
    ap = argparse.ArgumentParser(description=__doc__, formatter_class=argparse.RawDescriptionHelpFormatter)
    ap.add_argument("args", nargs="*",
                    help="[PORT] [DIR] — order-flexible; PORT must be 1024–65535")
    ns = ap.parse_args()

    port = 8765
    directory = Path.cwd()
    for a in ns.args:
        if a.isdigit() and 1 <= int(a) <= 65535:
            port = int(a)
        else:
            directory = Path(a).expanduser().resolve()

    if not directory.is_dir():
        print(f"error: not a directory: {directory}", file=sys.stderr)
        return 2

    handler = _make_handler(directory)
    httpd = ThreadingHTTPServer(("127.0.0.1", port), handler)
    sys.stderr.write(f"Serving {directory} on http://localhost:{port}/  (Range-capable)\n")
    try:
        httpd.serve_forever()
    except KeyboardInterrupt:
        sys.stderr.write("\nbye\n")
        httpd.server_close()
    return 0


if __name__ == "__main__":
    raise SystemExit(main())
