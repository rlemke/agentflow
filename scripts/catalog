#!/usr/bin/env bash
# Claude workflow catalog: backup / restore / import.
#
# Usage:
#   scripts/catalog backup catalog.json
#   scripts/catalog restore catalog.json [--no-recompile]
#   scripts/catalog import path/to/workflow.ffl --slug demo.x --publish
#   scripts/catalog import examples/dir/ --tags imported
#   scripts/catalog import-package osm-geocoder --tags osm
#
# Connects to MongoDB via .env (AFL_MONGODB_URL etc.).

set -euo pipefail

REPO_ROOT="$(cd "$(dirname "$0")/.." && pwd)"

# Load shared env (.env sets AFL_MONGODB_URL etc.)
source "$(dirname "$0")/_env.sh"

PYTHON="${REPO_ROOT}/.venv/bin/python3"
[[ -x "$PYTHON" ]] || PYTHON=python3

exec env PYTHONPATH="$REPO_ROOT" "$PYTHON" -m facetwork.catalog.cli "$@"
