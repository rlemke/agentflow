#!/usr/bin/env bash
# Manage the full-stack development environment defined by
# docker-compose.full-stack.yml: MongoDB + PostGIS + Jenkins + the
# Facetwork dashboard + the main runner + one dedicated runner per
# fwh_* example.
#
# Usage:
#   scripts/full-stack                          # start every service (detached)
#   scripts/full-stack up                       # same as no args
#   scripts/full-stack up runner-anthropic      # start specific services only
#   scripts/full-stack up --scale runner-osm-geocoder=3
#                                               # run 3 osm-geocoder replicas (any runner-* service
#                                               # is scalable; they all share the same task list and
#                                               # race for tasks via MongoDB's atomic claim).
#   scripts/full-stack down                     # stop + remove containers (keeps named volumes)
#   scripts/full-stack down --volumes           # also drop mongodb/postgis/jenkins data
#   scripts/full-stack stop                     # stop without removing
#   scripts/full-stack restart [SERVICE...]     # restart all or selected services
#   scripts/full-stack status                   # ps with health
#   scripts/full-stack logs [SERVICE...]        # tail -f logs
#   scripts/full-stack logs --tail 100 SERVICE  # snapshot of recent logs
#   scripts/full-stack build [SERVICE...]       # docker compose build
#   scripts/full-stack rebuild [--no-cache] [SERVICE...]  # build + recreate containers
#   scripts/full-stack pull                     # pull mongo / postgis / jenkins images
#   scripts/full-stack config                   # show resolved compose config
#   scripts/full-stack exec SERVICE [-- CMD]    # shell into a service
#   scripts/full-stack help                     # show this message
#
# Env vars (override in .env.full-stack or your shell):
#   FWH_HANDLERS_ROOT          default $HOME/fw_handlers
#   AFL_DATA_DIR               default /Volumes/afl_data
#   DASHBOARD_PORT             default 8080
#   AFL_MONGODB_PORT           default 27017
#   POSTGRES_PORT              default 5432
#   JENKINS_UI_PORT            default 9090
#   ANTHROPIC_API_KEY          pass-through to runner-anthropic
#   CENSUS_API_KEY             pass-through to runner-census-us
#   AFL_OSM_REPLICAS           # of osm-geocoder replicas (default 1)
#   AFL_ANTHROPIC_REPLICAS     # of anthropic replicas (default 1)
#   AFL_OSM_LZ_REPLICAS        # of osm-lz replicas (default 1)
#   AFL_WEATHER_REPLICAS       # of noaa-weather replicas (default 1)
#   AFL_JENKINS_REPLICAS       # of jenkins-example replicas (default 1)
#   AFL_CENSUS_REPLICAS        # of census-us replicas (default 1)
#   AFL_GENOMICS_REPLICAS      # of genomics replicas (default 1)
#   AFL_MONITOR_REPLICAS       # of sensor-monitoring replicas (default 1)
#   AFL_RUNNER_REPLICAS        # of main 'runner' replicas (default 1)
#   AFL_WORKFLOW_TASK_LIST_MAP `prefix=list,...` workflow→task-list routing
#                              (default in .env.full-stack.example)
#
# See docs/operations/full-stack-compose.md for the full reference,
# including workload partitioning by task list and the dashboard's
# runners-per-list health pill on /tasks.
#
# If a `.env.full-stack` file exists in the repo root it is used as the
# env-file; otherwise `.env.full-stack.example` (the checked-in
# template) is used. Pass `--env-file PATH` to override.

set -euo pipefail

SCRIPT_DIR="$(cd "$(dirname "$0")" && pwd)"
REPO_ROOT="$(cd "$SCRIPT_DIR/.." && pwd)"

COMPOSE_FILE="$REPO_ROOT/docker-compose.full-stack.yml"

if [[ -f "$REPO_ROOT/.env.full-stack" ]]; then
    ENV_FILE="$REPO_ROOT/.env.full-stack"
elif [[ -f "$REPO_ROOT/.env.full-stack.example" ]]; then
    ENV_FILE="$REPO_ROOT/.env.full-stack.example"
else
    echo "Error: neither .env.full-stack nor .env.full-stack.example found in $REPO_ROOT" >&2
    exit 1
fi

if [[ "${1:-}" == "--env-file" ]]; then
    ENV_FILE="$2"
    shift 2
fi

if [[ ! -f "$COMPOSE_FILE" ]]; then
    echo "Error: $COMPOSE_FILE not found." >&2
    exit 1
fi
if [[ ! -f "$ENV_FILE" ]]; then
    echo "Error: env file $ENV_FILE not found." >&2
    exit 1
fi

# Also source the env file into this shell so that build_scale_args (and
# any other host-side logic) can read AFL_*_REPLICAS etc. Without this,
# docker compose's --env-file only injects vars into the YAML's
# ${VAR:-} interpolation, leaving the script's own env empty.
set -a
# shellcheck disable=SC1090  # dynamic source path
source "$ENV_FILE"
set +a

compose() {
    docker compose --env-file "$ENV_FILE" -f "$COMPOSE_FILE" "$@"
}

# Build --scale args from AFL_<EXAMPLE>_REPLICAS env vars sourced from
# .env.full-stack. Set AFL_OSM_REPLICAS=3 (etc.) to bring up multiple
# replicas of a per-example runner. Empty / unset / 1 = no flag emitted.
# Returns nothing when no replica overrides are set, so existing
# `scripts/full-stack up` invocations keep the same single-replica
# behaviour.
build_scale_args() {
    set +u  # tolerate unset vars during the test below
    # service-name → env-var-name pairs
    local mapping=(
        "runner:AFL_RUNNER_REPLICAS"
        "runner-anthropic:AFL_ANTHROPIC_REPLICAS"
        "runner-osm-geocoder:AFL_OSM_REPLICAS"
        "runner-osm-lz:AFL_OSM_LZ_REPLICAS"
        "runner-noaa-weather:AFL_WEATHER_REPLICAS"
        "runner-jenkins-example:AFL_JENKINS_REPLICAS"
        "runner-census-us:AFL_CENSUS_REPLICAS"
        "runner-genomics:AFL_GENOMICS_REPLICAS"
        "runner-sensor-monitoring:AFL_MONITOR_REPLICAS"
    )
    local out=""
    for entry in "${mapping[@]}"; do
        local svc="${entry%%:*}"
        local var="${entry##*:}"
        local val="${!var:-}"
        if [[ -n "$val" && "$val" != "1" ]]; then
            out+=" --scale $svc=$val"
        fi
    done
    set -u
    echo "$out"
}

usage() {
    # Print the leading comment block (lines after the shebang, up to the
    # first non-comment line), stripped of the "# " prefix.
    sed -n '2,/^[^#]/p' "$0" | grep '^#' | sed 's/^# \{0,1\}//'
}

CMD="${1:-up}"
shift || true

case "$CMD" in
    -h|--help|help)
        usage
        ;;

    up)
        echo "Starting full-stack (env: $ENV_FILE)"
        # shellcheck disable=SC2046  # word-splitting the scale args is intentional
        compose up -d $(build_scale_args) "$@"
        echo
        compose ps --format "table {{.Service}}\t{{.Status}}"
        echo
        echo "Dashboard: http://localhost:${DASHBOARD_PORT:-8080}"
        echo "Jenkins:   http://localhost:${JENKINS_UI_PORT:-9090}"
        echo "Tail logs: scripts/full-stack logs"
        ;;

    down)
        if [[ "${1:-}" == "--volumes" || "${1:-}" == "-v" ]]; then
            echo "Stopping + removing containers AND named volumes (data will be wiped)"
            compose down -v
        else
            echo "Stopping + removing containers (named volumes kept)"
            compose down
        fi
        ;;

    stop)
        compose stop "$@"
        ;;

    restart)
        compose restart "$@"
        ;;

    status|ps)
        compose ps --format "table {{.Service}}\t{{.Status}}\t{{.Ports}}"
        ;;

    logs)
        if [[ $# -eq 0 ]]; then
            compose logs -f
        else
            compose logs "$@"
        fi
        ;;

    build)
        compose build "$@"
        ;;

    rebuild)
        # Rebuild images, then recreate any containers whose image changed.
        # Optional leading --no-cache forces a from-scratch build.
        nocache=""
        if [[ "${1:-}" == "--no-cache" ]]; then
            nocache="--no-cache"
            shift
        fi
        echo "Rebuilding images${1:+ for: $*}${nocache:+ (--no-cache)} (env: $ENV_FILE)"
        compose build $nocache "$@"
        echo
        echo "Recreating containers with the new images"
        # shellcheck disable=SC2046
        compose up -d $(build_scale_args) "$@"
        echo
        compose ps --format "table {{.Service}}\t{{.Status}}"
        echo
        echo "Dashboard: http://localhost:${DASHBOARD_PORT:-8080}"
        echo "Jenkins:   http://localhost:${JENKINS_UI_PORT:-9090}"
        echo "Tail logs: scripts/full-stack logs"
        ;;

    pull)
        compose pull "$@"
        ;;

    config)
        compose config "$@"
        ;;

    exec)
        if [[ $# -lt 1 ]]; then
            echo "Usage: scripts/full-stack exec SERVICE [-- CMD ...]" >&2
            exit 2
        fi
        service="$1"
        shift
        if [[ "${1:-}" == "--" ]]; then
            shift
        fi
        if [[ $# -eq 0 ]]; then
            compose exec "$service" /bin/bash
        else
            compose exec "$service" "$@"
        fi
        ;;

    *)
        echo "Unknown subcommand: $CMD" >&2
        echo
        usage >&2
        exit 2
        ;;
esac
