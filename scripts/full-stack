#!/usr/bin/env bash
# Manage the full-stack development environment defined by
# docker-compose.full-stack.yml: MongoDB + PostGIS + Jenkins + the
# Facetwork dashboard + the main runner + one dedicated runner per
# fwh_* example.
#
# Usage:
#   scripts/full-stack                          # start every service (detached)
#   scripts/full-stack up                       # same as no args
#   scripts/full-stack up runner-anthropic      # start specific services only
#   scripts/full-stack down                     # stop + remove containers (keeps named volumes)
#   scripts/full-stack down --volumes           # also drop mongodb/postgis/jenkins data
#   scripts/full-stack stop                     # stop without removing
#   scripts/full-stack restart [SERVICE...]     # restart all or selected services
#   scripts/full-stack status                   # ps with health
#   scripts/full-stack logs [SERVICE...]        # tail -f logs
#   scripts/full-stack logs --tail 100 SERVICE  # snapshot of recent logs
#   scripts/full-stack build [SERVICE...]       # docker compose build
#   scripts/full-stack pull                     # pull mongo / postgis / jenkins images
#   scripts/full-stack config                   # show resolved compose config
#   scripts/full-stack exec SERVICE [-- CMD]    # shell into a service
#   scripts/full-stack help                     # show this message
#
# Env vars (override in .env.full-stack or your shell):
#   FWH_HANDLERS_ROOT          default $HOME/fw_handlers
#   AFL_DATA_DIR               default /Volumes/afl_data
#   DASHBOARD_PORT             default 8080
#   AFL_MONGODB_PORT           default 27017
#   POSTGRES_PORT              default 5432
#   JENKINS_UI_PORT            default 9090
#   ANTHROPIC_API_KEY          pass-through to runner-anthropic
#   CENSUS_API_KEY             pass-through to runner-census-us
#
# If a `.env.full-stack` file exists in the repo root it is used as the
# env-file; otherwise `.env.full-stack.example` (the checked-in
# template) is used. Pass `--env-file PATH` to override.

set -euo pipefail

SCRIPT_DIR="$(cd "$(dirname "$0")" && pwd)"
REPO_ROOT="$(cd "$SCRIPT_DIR/.." && pwd)"

COMPOSE_FILE="$REPO_ROOT/docker-compose.full-stack.yml"

if [[ -f "$REPO_ROOT/.env.full-stack" ]]; then
    ENV_FILE="$REPO_ROOT/.env.full-stack"
elif [[ -f "$REPO_ROOT/.env.full-stack.example" ]]; then
    ENV_FILE="$REPO_ROOT/.env.full-stack.example"
else
    echo "Error: neither .env.full-stack nor .env.full-stack.example found in $REPO_ROOT" >&2
    exit 1
fi

if [[ "${1:-}" == "--env-file" ]]; then
    ENV_FILE="$2"
    shift 2
fi

if [[ ! -f "$COMPOSE_FILE" ]]; then
    echo "Error: $COMPOSE_FILE not found." >&2
    exit 1
fi
if [[ ! -f "$ENV_FILE" ]]; then
    echo "Error: env file $ENV_FILE not found." >&2
    exit 1
fi

compose() {
    docker compose --env-file "$ENV_FILE" -f "$COMPOSE_FILE" "$@"
}

usage() {
    sed -n '2,38p' "$0" | sed 's/^# \{0,1\}//'
}

CMD="${1:-up}"
shift || true

case "$CMD" in
    -h|--help|help)
        usage
        ;;

    up)
        echo "Starting full-stack (env: $ENV_FILE)"
        compose up -d "$@"
        echo
        compose ps --format "table {{.Service}}\t{{.Status}}"
        echo
        echo "Dashboard: http://localhost:${DASHBOARD_PORT:-8080}"
        echo "Jenkins:   http://localhost:${JENKINS_UI_PORT:-9090}"
        echo "Tail logs: scripts/full-stack logs"
        ;;

    down)
        if [[ "${1:-}" == "--volumes" || "${1:-}" == "-v" ]]; then
            echo "Stopping + removing containers AND named volumes (data will be wiped)"
            compose down -v
        else
            echo "Stopping + removing containers (named volumes kept)"
            compose down
        fi
        ;;

    stop)
        compose stop "$@"
        ;;

    restart)
        compose restart "$@"
        ;;

    status|ps)
        compose ps --format "table {{.Service}}\t{{.Status}}\t{{.Ports}}"
        ;;

    logs)
        if [[ $# -eq 0 ]]; then
            compose logs -f
        else
            compose logs "$@"
        fi
        ;;

    build)
        compose build "$@"
        ;;

    pull)
        compose pull "$@"
        ;;

    config)
        compose config "$@"
        ;;

    exec)
        if [[ $# -lt 1 ]]; then
            echo "Usage: scripts/full-stack exec SERVICE [-- CMD ...]" >&2
            exit 2
        fi
        service="$1"
        shift
        if [[ "${1:-}" == "--" ]]; then
            shift
        fi
        if [[ $# -eq 0 ]]; then
            compose exec "$service" /bin/bash
        else
            compose exec "$service" "$@"
        fi
        ;;

    *)
        echo "Unknown subcommand: $CMD" >&2
        echo
        usage >&2
        exit 2
        ;;
esac
