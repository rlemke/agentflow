// AI Research Agent — fwh_anthropic-powered version
//
// Each event facet's handler calls `anthropic.messages.create_message`
// (via fwh_anthropic's Python lib) with a domain-specific system
// prompt that asks Claude to return JSON in a documented shape, then
// parses the response into the schema-typed result. The FFL surface
// stays simple — 8 event facets, one per research stage — while the
// fwh_anthropic dependency lives at the handler boundary.
//
// Why not composed facets calling `anthropic.messages.CreateMessage`
// from FFL directly? That's the cleaner architecture, but the
// facetwork runtime currently doesn't propagate composed-facet yield
// outputs when the body contains an event facet (which pauses for
// the agent). See the project's lessons-learned doc for the planned
// fix. Until then, handler-level use of fwh_anthropic is the working
// path — and it still proves "research-agent runs on top of
// fwh_anthropic" end-to-end.
//
// Demonstrates:
//   - Cross-package Python dependency (handlers import
//     `anthropic_handlers.tools._lib.messages`)
//   - Statement-level andThen, andThen foreach, mixins, implicits,
//     array literals, schemas, doc comments — same surface as before

// -----------------------------------------------------------------------
// Types
// -----------------------------------------------------------------------
/** Shared type definitions for the research agent pipeline. */
namespace research.types {
    /** A research topic with depth, keywords, and subtopic limits. */
    schema Topic {
        name: String,
        depth: Long,
        keywords: Json,
        summary: String,
        max_subtopics: Long
    }

    /** A subtopic derived from a parent topic for focused investigation. */
    schema Subtopic {
        name: String,
        parent_topic: String,
        description: String,
        priority: Long
    }

    /** A research source with title, URL, and relevance score. */
    schema Source {
        title: String,
        url: String,
        relevance_score: Double,
        source_type: String
    }

    /** A factual finding extracted from a source with confidence level. */
    schema Finding {
        claim: String,
        evidence: String,
        confidence: Double,
        source_title: String
    }

    /** Synthesized analysis with themes, contradictions, and knowledge gaps. */
    schema Analysis {
        themes: Json,
        contradictions: Json,
        gaps: Json,
        summary: String,
        confidence_score: Double
    }

    /** A draft research report with sections and citations. */
    schema Draft {
        title: String,
        sections: Json,
        word_count: Long,
        citations: Json
    }

    /** Peer review result with score, approval status, and feedback. */
    schema ReviewResult {
        score: Long,
        approved: Boolean,
        feedback: Json,
        suggested_edits: Json
    }
}

// -----------------------------------------------------------------------
// Mixins
// -----------------------------------------------------------------------
/** Cross-cutting concerns for research steps. */
namespace research.mixins {
    /** Retry policy with configurable attempts and backoff. */
    facet Retry(max_attempts: Int = 3, backoff_ms: Int = 2000)
    /** Citation formatting configuration. */
    facet Citation(style: String = "apa", include_urls: Boolean = true)

    implicit defaultRetry = Retry(max_attempts = 3, backoff_ms = 2000)
    implicit defaultCitation = Citation(style = "apa", include_urls = true)
}

// -----------------------------------------------------------------------
// Planning
// -----------------------------------------------------------------------
/** Research planning and topic decomposition. */
namespace research.Planning {
    use research.types

    /** Plan a research investigation by asking Claude to return JSON. */
    event facet PlanResearch(
        topic: String,
        depth: Long = 3,
        max_subtopics: Long = 5
    ) => (plan: Topic)

    /** Decompose a topic into focused subtopics for parallel investigation. */
    event facet DecomposeIntoSubtopics(
        topic: Topic,
        max_subtopics: Long = 5
    ) => (subtopics: Json)
}

// -----------------------------------------------------------------------
// Gathering
// -----------------------------------------------------------------------
/** Source gathering and finding extraction. */
namespace research.Gathering {
    use research.types

    /** Ask Claude to suggest authoritative sources for a subtopic. */
    event facet GatherSources(
        subtopic: Subtopic,
        max_sources: Long = 5
    ) => (sources: Json)

    /** Extract structured findings from a list of sources. */
    event facet ExtractFindings(
        subtopic: Subtopic,
        sources: Json
    ) => (findings: Json)
}

// -----------------------------------------------------------------------
// Analysis
// -----------------------------------------------------------------------
/** Finding synthesis and gap identification. */
namespace research.Analysis {
    use research.types

    /** Synthesize findings across subtopics into a cohesive analysis. */
    event facet SynthesizeFindings(
        topic: Topic,
        all_findings: Json
    ) => (analysis: Analysis)

    /** Identify methodological gaps and recommend concrete next steps. */
    event facet IdentifyGaps(
        analysis: Analysis,
        topic: Topic
    ) => (gaps: Json, recommendations: Json)
}

// -----------------------------------------------------------------------
// Writing
// -----------------------------------------------------------------------
/** Report drafting and peer review. */
namespace research.Writing {
    use research.types

    /** Draft a research report from the analysis. */
    event facet DraftReport(
        topic: Topic,
        analysis: Analysis,
        gaps: Json
    ) => (draft: Draft)

    /** Peer-review a draft for quality, accuracy, and completeness. */
    event facet ReviewDraft(
        draft: Draft,
        topic: Topic,
        analysis: Analysis
    ) => (review: ReviewResult)
}

// -----------------------------------------------------------------------
// Workflows
// -----------------------------------------------------------------------
/** Top-level research workflows. */
namespace research.workflows {
    use research.types
    use research.mixins
    use research.Planning
    use research.Gathering
    use research.Analysis
    use research.Writing

    /** Research a topic end-to-end: plan, gather, analyze, write, and review. */
    workflow ResearchTopic(
        topic: String,
        depth: Long = 3,
        max_subtopics: Long = 3,
        sources_per_subtopic: Long = 3
    ) => (
        report: Draft,
        review: ReviewResult,
        total_sources: Long,
        summary: String
    ) script {
        result["total_sources"] = int(params.get("max_subtopics", 3)) * int(params.get("sources_per_subtopic", 3))
        result["summary"] = "Research pipeline for: " + params.get("topic", "unknown")
    } andThen {
        planned = PlanResearch(topic = $.topic, depth = $.depth, max_subtopics = $.max_subtopics) with Retry(max_attempts = 3, backoff_ms = 2000) with Citation(style = "apa", include_urls = true)
        decomp = DecomposeIntoSubtopics(topic = planned.plan, max_subtopics = $.max_subtopics)
        g0 = GatherSources(subtopic = decomp.subtopics[0], max_sources = $.sources_per_subtopic) with Retry(max_attempts = 3) andThen {
            f0 = ExtractFindings(subtopic = decomp.subtopics[0], sources = g0.sources)
        }
        g1 = GatherSources(subtopic = decomp.subtopics[1], max_sources = $.sources_per_subtopic) with Retry(max_attempts = 3) andThen {
            f1 = ExtractFindings(subtopic = decomp.subtopics[1], sources = g1.sources)
        }
        g2 = GatherSources(subtopic = decomp.subtopics[2], max_sources = $.sources_per_subtopic) with Retry(max_attempts = 3) andThen {
            f2 = ExtractFindings(subtopic = decomp.subtopics[2], sources = g2.sources)
        }
        synth = SynthesizeFindings(topic = planned.plan, all_findings = [f0.findings, f1.findings, f2.findings])
        gapcheck = IdentifyGaps(analysis = synth.analysis, topic = planned.plan)
        report = DraftReport(topic = planned.plan, analysis = synth.analysis, gaps = gapcheck.gaps)
        rev = ReviewDraft(draft = report.draft, topic = planned.plan, analysis = synth.analysis)
        yield ResearchTopic(report = report.draft, review = rev.review, total_sources = $.total_sources, summary = $.summary)
    } andThen script {
        result["summary"] = (
            "Completed research on: " + params.get("topic", "unknown")
            + " with " + str(params.get("total_sources", 0))
            + " total sources"
        )
    }

    /**
     * Linear single-subtopic variant used by `run.py` for end-to-end
     * smoke testing. The full `ResearchTopic` workflow above uses
     * statement-level `andThen` fan-out (g0/g1/g2 in parallel), which
     * the current Facetwork runtime cannot drive to completion via
     * `AgentPoller` against `MemoryStore` (workflow gets stuck partway
     * through). The fix lives in the runtime — until it lands, this
     * linear shape exercises the same handler chain top-to-bottom.
     */
    workflow ResearchTopicLinear(
        topic: String,
        depth: Long = 3,
        max_subtopics: Long = 1,
        sources_per_subtopic: Long = 3
    ) => (
        report: Draft,
        review: ReviewResult,
        summary: String
    ) andThen {
        planned = PlanResearch(topic = $.topic, depth = $.depth, max_subtopics = $.max_subtopics)
        decomp = DecomposeIntoSubtopics(topic = planned.plan, max_subtopics = $.max_subtopics)
        g0 = GatherSources(subtopic = decomp.subtopics[0], max_sources = $.sources_per_subtopic)
        f0 = ExtractFindings(subtopic = decomp.subtopics[0], sources = g0.sources)
        synth = SynthesizeFindings(topic = planned.plan, all_findings = f0.findings)
        gapcheck = IdentifyGaps(analysis = synth.analysis, topic = planned.plan)
        report = DraftReport(topic = planned.plan, analysis = synth.analysis, gaps = gapcheck.gaps)
        rev = ReviewDraft(draft = report.draft, topic = planned.plan, analysis = synth.analysis)
        yield ResearchTopicLinear(report = report.draft, review = rev.review, summary = "linear smoke run")
    }

    /** Deep-dive: foreach fan-out for parallel subtopic investigation. */
    workflow DeepDive(
        topic: String,
        depth: Long = 5,
        max_subtopics: Long = 5,
        max_sources: Long = 5
    ) => (
        plan: Topic,
        subtopics: Json
    ) andThen {
        planned = PlanResearch(topic = $.topic, depth = $.depth, max_subtopics = $.max_subtopics) with Citation(style = "ieee", include_urls = true)
        decomp = DecomposeIntoSubtopics(topic = planned.plan, max_subtopics = $.max_subtopics)
        yield DeepDive(plan = planned.plan, subtopics = decomp.subtopics)
    } andThen foreach sub in $.subtopics {
        g = GatherSources(subtopic = $.sub, max_sources = $.max_sources) with Retry(max_attempts = 5, backoff_ms = 3000) andThen {
            f = ExtractFindings(subtopic = $.sub, sources = g.sources)
        }
        yield DeepDive(subtopics = f.findings)
    }
}
