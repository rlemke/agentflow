// AI Research Agent — fwh_anthropic-powered version
//
// Each domain step is a composed facet (not event) that
//   (a) calls anthropic.messages.CreateMessage with a domain prompt
//   (b) hands the response text to a typed `Parse<X>` event facet
// The parsers are the only handlers — pure JSON-to-schema conversion,
// with no Claude knowledge. The workflow body is unchanged from the
// original prompt-block version: it still calls PlanResearch(...),
// GatherSources(...), etc.
//
// Demonstrates:
//   - Cross-package FFL composition (depends on fwh_anthropic for
//     anthropic.messages.* facets)
//   - Composed facets wrapping event facets from another namespace
//   - Statement-level andThen, andThen foreach, mixins, implicits,
//     array literals, schemas, doc comments — same surface as before

// -----------------------------------------------------------------------
// Types
// -----------------------------------------------------------------------
/** Shared type definitions for the research agent pipeline. */
namespace research.types {
    /** A research topic with depth, keywords, and subtopic limits. */
    schema Topic {
        name: String,
        depth: Long,
        keywords: Json,
        summary: String,
        max_subtopics: Long
    }

    /** A subtopic derived from a parent topic for focused investigation. */
    schema Subtopic {
        name: String,
        parent_topic: String,
        description: String,
        priority: Long
    }

    /** A research source with title, URL, and relevance score. */
    schema Source {
        title: String,
        url: String,
        relevance_score: Double,
        source_type: String
    }

    /** A factual finding extracted from a source with confidence level. */
    schema Finding {
        claim: String,
        evidence: String,
        confidence: Double,
        source_title: String
    }

    /** Synthesized analysis with themes, contradictions, and knowledge gaps. */
    schema Analysis {
        themes: Json,
        contradictions: Json,
        gaps: Json,
        summary: String,
        confidence_score: Double
    }

    /** A draft research report with sections and citations. */
    schema Draft {
        title: String,
        sections: Json,
        word_count: Long,
        citations: Json
    }

    /** Peer review result with score, approval status, and feedback. */
    schema ReviewResult {
        score: Long,
        approved: Boolean,
        feedback: Json,
        suggested_edits: Json
    }

    /** Pair returned by IdentifyGaps. */
    schema GapsAndRecs {
        gaps: Json,
        recommendations: Json
    }
}

// -----------------------------------------------------------------------
// Mixins
// -----------------------------------------------------------------------
/** Cross-cutting concerns for research steps. */
namespace research.mixins {
    /** Retry policy with configurable attempts and backoff. */
    facet Retry(max_attempts: Int = 3, backoff_ms: Int = 2000)
    /** Citation formatting configuration. */
    facet Citation(style: String = "apa", include_urls: Boolean = true)

    implicit defaultRetry = Retry(max_attempts = 3, backoff_ms = 2000)
    implicit defaultCitation = Citation(style = "apa", include_urls = true)
}

// -----------------------------------------------------------------------
// Planning
// -----------------------------------------------------------------------
/** Research planning and topic decomposition. */
namespace research.Planning {
    use anthropic.messages
    use research.types

    /** Parse Claude's planning JSON into a Topic. */
    event facet ParseTopic(
        text: String,
        topic_name: String,
        depth: Long,
        max_subtopics: Long) => (plan: Topic)

    /** Parse Claude's decomposition JSON into a Subtopic list. */
    event facet ParseSubtopics(
        text: String,
        parent_topic: String,
        max_subtopics: Long) => (subtopics: Json)

    /** Plan a research investigation by asking Claude to return JSON. */
    facet PlanResearch(
        topic: String,
        depth: Long = 3,
        max_subtopics: Long = 5
    ) => (plan: Topic) andThen {
        reply = anthropic.messages.CreateMessage(
            system = "You are a research planning assistant. Reply with one JSON object only, no prose. Schema: {\"name\": string, \"depth\": int, \"keywords\": [string], \"summary\": string, \"max_subtopics\": int}.",
            prompt = "Plan a research investigation on '" ++ $.topic ++ "'. Identify up to " ++ $.max_subtopics ++ " key subtopics. Return JSON only.",
            max_tokens = 1024)
        parsed = ParseTopic(
            text = reply.result.text,
            topic_name = $.topic,
            depth = $.depth,
            max_subtopics = $.max_subtopics)
        yield PlanResearch(plan = parsed.plan)
    }

    /** Decompose a topic into focused subtopics for parallel investigation. */
    facet DecomposeIntoSubtopics(
        topic: Topic,
        max_subtopics: Long = 5
    ) => (subtopics: Json) andThen {
        reply = anthropic.messages.CreateMessage(
            system = "You are a research decomposition expert. Reply with one JSON array of subtopic objects, no prose. Each: {\"name\": string, \"parent_topic\": string, \"description\": string, \"priority\": int}.",
            prompt = "Decompose '" ++ $.topic.name ++ "' into at most " ++ $.max_subtopics ++ " subtopics. Return JSON only.",
            max_tokens = 1024)
        parsed = ParseSubtopics(
            text = reply.result.text,
            parent_topic = $.topic.name,
            max_subtopics = $.max_subtopics)
        yield DecomposeIntoSubtopics(subtopics = parsed.subtopics)
    }
}

// -----------------------------------------------------------------------
// Gathering
// -----------------------------------------------------------------------
/** Source gathering and finding extraction. */
namespace research.Gathering {
    use anthropic.messages
    use research.types

    /** Parse Claude's source-list JSON into a Source list. */
    event facet ParseSources(
        text: String,
        subtopic_name: String,
        max_sources: Long) => (sources: Json)

    /** Parse Claude's findings JSON into a Finding list. */
    event facet ParseFindings(
        text: String,
        subtopic_name: String) => (findings: Json)

    /** Ask Claude to suggest authoritative sources for a subtopic. */
    facet GatherSources(
        subtopic: Subtopic,
        max_sources: Long = 5
    ) => (sources: Json) andThen {
        reply = anthropic.messages.CreateMessage(
            system = "You are a research librarian. Reply with one JSON array of source objects, no prose. Each: {\"title\": string, \"url\": string, \"relevance_score\": number, \"source_type\": string}.",
            prompt = "Find up to " ++ $.max_sources ++ " authoritative sources for subtopic '" ++ $.subtopic.name ++ "' (" ++ $.subtopic.description ++ "). Prefer peer-reviewed. Return JSON only.",
            max_tokens = 1024)
        parsed = ParseSources(
            text = reply.result.text,
            subtopic_name = $.subtopic.name,
            max_sources = $.max_sources)
        yield GatherSources(sources = parsed.sources)
    }

    /** Extract structured findings from a list of sources. */
    facet ExtractFindings(
        subtopic: Subtopic,
        sources: Json
    ) => (findings: Json) andThen {
        reply = anthropic.messages.CreateMessage(
            system = "You are a research analyst. Reply with one JSON array of finding objects, no prose. Each: {\"claim\": string, \"evidence\": string, \"confidence\": number (0-1), \"source_title\": string}.",
            prompt = "Extract key findings about '" ++ $.subtopic.name ++ "' from these sources. Return JSON only.",
            max_tokens = 1024)
        parsed = ParseFindings(
            text = reply.result.text,
            subtopic_name = $.subtopic.name)
        yield ExtractFindings(findings = parsed.findings)
    }
}

// -----------------------------------------------------------------------
// Analysis
// -----------------------------------------------------------------------
/** Finding synthesis and gap identification. */
namespace research.Analysis {
    use anthropic.messages
    use research.types

    /** Parse Claude's synthesis JSON into an Analysis. */
    event facet ParseAnalysis(
        text: String,
        topic_name: String) => (analysis: Analysis)

    /** Parse Claude's gaps + recommendations JSON. */
    event facet ParseGaps(
        text: String,
        topic_name: String) => (result: GapsAndRecs)

    /** Synthesize findings across subtopics into a cohesive analysis. */
    facet SynthesizeFindings(
        topic: Topic,
        all_findings: Json
    ) => (analysis: Analysis) andThen {
        reply = anthropic.messages.CreateMessage(
            system = "You are a research synthesizer. Reply with one JSON object: {\"themes\": [string], \"contradictions\": [string], \"gaps\": [string], \"summary\": string, \"confidence_score\": number (0-1)}.",
            prompt = "Synthesize findings for '" ++ $.topic.name ++ "'. Identify themes, contradictions across sources, and remaining gaps. Return JSON only.",
            max_tokens = 1024)
        parsed = ParseAnalysis(
            text = reply.result.text,
            topic_name = $.topic.name)
        yield SynthesizeFindings(analysis = parsed.analysis)
    }

    /** Identify methodological gaps and recommend concrete next steps. */
    facet IdentifyGaps(
        analysis: Analysis,
        topic: Topic
    ) => (gaps: Json, recommendations: Json) andThen {
        reply = anthropic.messages.CreateMessage(
            system = "You are a research quality reviewer. Reply with one JSON object: {\"gaps\": [{\"description\": string, \"severity\": \"high\"|\"medium\"|\"low\", \"area\": string}], \"recommendations\": [{\"action\": string, \"priority\": string, \"estimated_effort\": string}]}.",
            prompt = "Review the analysis of '" ++ $.topic.name ++ "' (confidence " ++ $.analysis.confidence_score ++ "). Suggest concrete next steps. Return JSON only.",
            max_tokens = 1024)
        parsed = ParseGaps(
            text = reply.result.text,
            topic_name = $.topic.name)
        yield IdentifyGaps(
            gaps = parsed.result.gaps,
            recommendations = parsed.result.recommendations)
    }
}

// -----------------------------------------------------------------------
// Writing
// -----------------------------------------------------------------------
/** Report drafting and peer review. */
namespace research.Writing {
    use anthropic.messages
    use research.types

    /** Parse Claude's draft JSON into a Draft. */
    event facet ParseDraft(
        text: String,
        topic_name: String) => (draft: Draft)

    /** Parse Claude's review JSON into a ReviewResult. */
    event facet ParseReview(
        text: String,
        topic_name: String) => (review: ReviewResult)

    /** Draft a research report from the analysis. */
    facet DraftReport(
        topic: Topic,
        analysis: Analysis,
        gaps: Json
    ) => (draft: Draft) andThen {
        reply = anthropic.messages.CreateMessage(
            system = "You are a technical writer. Reply with one JSON object: {\"title\": string, \"sections\": [{\"title\": string, \"content\": string}], \"word_count\": int, \"citations\": [string]}.",
            prompt = "Draft a research report on '" ++ $.topic.name ++ "'. Use the analysis themes and gaps. Be concise. Return JSON only.",
            max_tokens = 2048)
        parsed = ParseDraft(
            text = reply.result.text,
            topic_name = $.topic.name)
        yield DraftReport(draft = parsed.draft)
    }

    /** Peer-review a draft for quality, accuracy, and completeness. */
    facet ReviewDraft(
        draft: Draft,
        topic: Topic,
        analysis: Analysis
    ) => (review: ReviewResult) andThen {
        reply = anthropic.messages.CreateMessage(
            system = "You are a peer reviewer. Reply with one JSON object: {\"score\": int 0-100, \"approved\": bool, \"feedback\": [string], \"suggested_edits\": [{\"section\": string, \"suggestion\": string}]}.",
            prompt = "Review '" ++ $.draft.title ++ "' (" ++ $.draft.word_count ++ " words) on '" ++ $.topic.name ++ "'. Score 0-100. Return JSON only.",
            max_tokens = 1024)
        parsed = ParseReview(
            text = reply.result.text,
            topic_name = $.topic.name)
        yield ReviewDraft(review = parsed.review)
    }
}

// -----------------------------------------------------------------------
// Workflows
// -----------------------------------------------------------------------
/** Top-level research workflows. */
namespace research.workflows {
    use research.types
    use research.mixins
    use research.Planning
    use research.Gathering
    use research.Analysis
    use research.Writing

    /** Research a topic end-to-end: plan, gather, analyze, write, and review. */
    workflow ResearchTopic(
        topic: String,
        depth: Long = 3,
        max_subtopics: Long = 3,
        sources_per_subtopic: Long = 3
    ) => (
        report: Draft,
        review: ReviewResult,
        total_sources: Long,
        summary: String
    ) script {
        result["total_sources"] = int(params.get("max_subtopics", 3)) * int(params.get("sources_per_subtopic", 3))
        result["summary"] = "Research pipeline for: " + params.get("topic", "unknown")
    } andThen {
        plan = PlanResearch(topic = $.topic, depth = $.depth, max_subtopics = $.max_subtopics) with Retry(max_attempts = 3, backoff_ms = 2000) with Citation(style = "apa", include_urls = true)
        decomp = DecomposeIntoSubtopics(topic = plan.plan, max_subtopics = $.max_subtopics)
        g0 = GatherSources(subtopic = decomp.subtopics[0], max_sources = $.sources_per_subtopic) with Retry(max_attempts = 3) andThen {
            f0 = ExtractFindings(subtopic = decomp.subtopics[0], sources = g0.sources)
        }
        g1 = GatherSources(subtopic = decomp.subtopics[1], max_sources = $.sources_per_subtopic) with Retry(max_attempts = 3) andThen {
            f1 = ExtractFindings(subtopic = decomp.subtopics[1], sources = g1.sources)
        }
        g2 = GatherSources(subtopic = decomp.subtopics[2], max_sources = $.sources_per_subtopic) with Retry(max_attempts = 3) andThen {
            f2 = ExtractFindings(subtopic = decomp.subtopics[2], sources = g2.sources)
        }
        synth = SynthesizeFindings(topic = plan.plan, all_findings = [f0.findings, f1.findings, f2.findings])
        gapcheck = IdentifyGaps(analysis = synth.analysis, topic = plan.plan)
        report = DraftReport(topic = plan.plan, analysis = synth.analysis, gaps = gapcheck.gaps)
        rev = ReviewDraft(draft = report.draft, topic = plan.plan, analysis = synth.analysis)
        yield ResearchTopic(report = report.draft, review = rev.review, total_sources = $.total_sources, summary = $.summary)
    } andThen script {
        result["summary"] = (
            "Completed research on: " + params.get("topic", "unknown")
            + " with " + str(params.get("total_sources", 0))
            + " total sources"
        )
    }

    /** Deep-dive: foreach fan-out for parallel subtopic investigation. */
    workflow DeepDive(
        topic: String,
        depth: Long = 5,
        max_subtopics: Long = 5,
        max_sources: Long = 5
    ) => (
        plan: Topic,
        subtopics: Json
    ) andThen {
        plan = PlanResearch(topic = $.topic, depth = $.depth, max_subtopics = $.max_subtopics) with Citation(style = "ieee", include_urls = true)
        decomp = DecomposeIntoSubtopics(topic = plan.plan, max_subtopics = $.max_subtopics)
        yield DeepDive(plan = plan.plan, subtopics = decomp.subtopics)
    } andThen foreach sub in $.subtopics {
        g = GatherSources(subtopic = $.sub, max_sources = $.max_sources) with Retry(max_attempts = 5, backoff_ms = 3000) andThen {
            f = ExtractFindings(subtopic = $.sub, sources = g.sources)
        }
        yield DeepDive(subtopics = f.findings)
    }
}
