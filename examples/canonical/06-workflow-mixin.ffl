// Mixin composition — extra return attributes attached to a facet/workflow.
//
// `with FacetA()` on a signature makes the mixin's return attributes
// part of what callers can yield to. A single yield may target the
// containing facet AND any of its mixins via a `with` chain, or each
// target may be written as its own `yield` statement — the two forms
// produce identical AST.

namespace audit {
    facet Timestamp() => (at: String)
    event facet Charge(account: String, amount: Long) => (txn_id: String)

    workflow ChargeWithAudit(account: String, amount: Long, at: String) => (txn_id: String, at: String) with Timestamp() andThen {
        charged = Charge(account = $.account, amount = $.amount)
        // Chained form — symmetric with how mixins attach to the
        // workflow signature above:
        yield ChargeWithAudit(txn_id = charged.txn_id)
            with Timestamp(at = $.at)
    }
}
