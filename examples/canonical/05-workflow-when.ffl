// when block — branch on a Boolean condition.
//
// A when block must have at least one case AND a default (`case _ =>`)
// that comes last. Conditions must evaluate to Boolean.

namespace classify {
    event facet Score(text: String) => (score: Long)
    event facet RouteHigh(text: String) => (label: String)
    event facet RouteLow(text: String) => (label: String)

    workflow Classify(text: String) => (label: String) andThen {
        scored = Score(text = $.text)
    } andThen when {
        case scored.score > 50 => {
            high = RouteHigh(text = $.text)
            yield Classify(label = high.label)
        }
        case _ => {
            low = RouteLow(text = $.text)
            yield Classify(label = low.label)
        }
    }
}
