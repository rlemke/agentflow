namespace weather.Cache {
    use weather.types

    /** Cache NOAA data for all 13 Canadian provinces/territories. */
    workflow CacheCanadaData(provinces: [String] = ["AB","BC","MB","NB","NL","NS","NT","NU","ON","PE","QC","SK","YT"], max_stations: Int = 5, start_year: Int = 1944, end_year: Int = 2024) => (status: String) andThen foreach province in $.provinces {
        cache = CacheStateData(country = "CA", state = $.province, max_stations = $.max_stations, start_year = $.start_year, end_year = $.end_year) catch {
            yield CacheCanadaData(status = "partial")
        }
    } andThen {
        yield CacheCanadaData(status = "completed")
