# Environment overrides for docker-compose.full-stack.yml
#
# Copy to `.env.full-stack` and load via:
#   docker compose --env-file .env.full-stack -f docker-compose.full-stack.yml up -d

# Where the fwh_* repos are cloned on the host.  Each runner bind-mounts
# $FWH_HANDLERS_ROOT/fwh_<name> into /handlers/fwh_<name>.
FWH_HANDLERS_ROOT=${HOME}/fw_handlers

# Shared data root.  All runners mount this so caches + outputs live
# in one place.  /Volumes/afl_data is the macOS-friendly default; on
# Linux point this at a regular path with enough space.
AFL_DATA_DIR=/Volumes/afl_data

# Port mappings (override if these clash on your host).
DASHBOARD_PORT=8080
AFL_MONGODB_PORT=27017
POSTGRES_PORT=5432
JENKINS_UI_PORT=9090
JENKINS_AGENT_PORT=50000

# PostGIS credentials.
POSTGRES_DB=afl_gis
POSTGRES_USER=afl
POSTGRES_PASSWORD=afl

# Examples database (dashboard reads this to show the catalog).
AFL_EXAMPLES_DATABASE=afl_examples

# Runner tuning.
AFL_MAX_CONCURRENT=4
AFL_POLL_INTERVAL_MS=1000

# Per-example secrets (leave blank if you only want to compile/seed,
# not actually call the upstream services).
ANTHROPIC_API_KEY=
CENSUS_API_KEY=

# fwh_anthropic extras — `agent_sdk` pulls claude-agent-sdk, `mcp`
# pulls the mcp SDK.  Set to empty if you only need the bare
# anthropic SDK.
ANTHROPIC_EXTRAS=agent_sdk,mcp

# Workflow→task-list routing. Longest-prefix wins; empty prefix sets the
# global fallback (otherwise "default"). The dashboard and per-example
# runners read this to decide which list a workflow's bootstrap + child
# event tasks land on. Combine with --task-list on each runner (set in
# docker-compose.full-stack.yml) to isolate workloads — a flooded OSM
# import can't starve an anthropic call when each runs on its own queue.
AFL_WORKFLOW_TASK_LIST_MAP=osm.=osm,continental.=continental,anthropic.=anthropic,weather.=weather,jenkins.=jenkins,census.=census,genomics.=genomics,monitor.=monitor
