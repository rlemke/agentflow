# AgentFlow Environment Configuration
# Copy to .env and customize. Scripts source this automatically.
# Precedence: command-line flags > env vars > .env > defaults

# MongoDB (external server at afl-mongodb, defined in /etc/hosts)
AFL_MONGODB_URL=mongodb://afl-mongodb:27017
AFL_MONGODB_DATABASE=afl
AFL_EXAMPLES_DATABASE=afl_examples

# Scaling
AFL_RUNNERS=2
AFL_AGENTS=2
AFL_OSM_AGENTS=2
AFL_OSM_LITE_AGENTS=2
AFL_WEATHER_AGENTS=2

# Runner tuning
# AFL_MAX_CONCURRENT=2
# AFL_POLL_INTERVAL_MS=1000
# AFL_REAPER_TIMEOUT_MS=300000  # Orphan reaper timeout (default 5min; increase for large files)

# Overlays
AFL_HDFS=false
AFL_POSTGIS=false
AFL_JENKINS=false
AFL_GEOFABRIK_MIRROR=/Volumes/afl_data/osm

# OSM cache directory (HDFS URI or local path; empty = /tmp/osm-cache)
# AFL_CACHE_DIR=hdfs://afl-hadoop-hdfs:8020/osm-cache
# AFL_CACHE_DIR=/Volumes/afl_data/osm-cache

# OSM extractor output base (HDFS URI or local path; empty = /tmp)
# AFL_OSM_OUTPUT_BASE=hdfs://afl-hadoop-hdfs:8020/osm-output
# AFL_OSM_OUTPUT_BASE=/Volumes/afl_data/osm-output

# Local output directory for handler files (HTML maps, stats, GeoJSON)
# Mounted from host into Docker containers. Default: /Volumes/afl_data/output
# AFL_LOCAL_OUTPUT_DIR=/Volumes/afl_data/output

# LLM (Claude API for prompt-block event facets)
# ANTHROPIC_API_KEY=

# Remote runner management
# AFL_RUNNER_HOSTS=host1 host2 host3
# AFL_REMOTE_PATH=/opt/agentflow
# AFL_SSH_OPTS=

# External data dirs (leave empty for Docker volumes)
# HDFS_NAMENODE_DIR=
# HDFS_DATANODE_DIR=
# GRAPHHOPPER_DATA_DIR=
# POSTGIS_DATA_DIR=
# JENKINS_HOME_DIR=
