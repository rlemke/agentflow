# AgentFlow Runner Service
FROM python:3.12-slim

WORKDIR /app

# Install dependencies
COPY pyproject.toml .
RUN pip install --no-cache-dir -e ".[mongodb]" || \
    pip install --no-cache-dir lark pymongo

# System packages for osmium-tool (boundary extraction)
RUN apt-get update && apt-get install -y --no-install-recommends \
    osmium-tool \
    && rm -rf /var/lib/apt/lists/*

# HDFS support uses WebHDFS REST API via requests (no native libs needed)
# pyshp needed for census-us TIGER shapefiles
# folium needed for noaa-weather station maps
# osm2geojson needed for boundary extraction (type=boundary relations)
RUN pip install --no-cache-dir requests pyshp folium osm2geojson

# Copy application code. The package is `facetwork`, not `afl`; the
# earlier `./afl/` rename was a relic of the project's rename and
# broke imports like `from facetwork.logging import ...`.
COPY facetwork/ ./facetwork/

# Two-step entrypoint: seed in-repo example handlers into MongoDB, then
# start the runner in --registry mode so it actually advertises (and
# claims tasks for) the facets it can dispatch. See docker/entrypoint-runner.sh
# for the rationale; without this the main runner registers only fw:execute
# and child event tasks for in-repo examples pile up on the default queue
# with no listener.
COPY docker/entrypoint-runner.sh /entrypoint-runner.sh
RUN chmod +x /entrypoint-runner.sh

ENV PYTHONUNBUFFERED=1
ENV AFL_POLL_INTERVAL_MS=1000
CMD ["/entrypoint-runner.sh"]
