# Generic per-example Facetwork runner.
#
# One image; the example to run is passed via AFL_EXAMPLE_NAME. The
# example's source (one of the fwh_* repos) is bind-mounted at
# /handlers/$AFL_EXAMPLE_REPO and pip-installed at container start by
# entrypoint-example-runner.sh.
#
# Why bind-mount + install at start, instead of baking the example
# into the image? Two reasons:
#   1. Each runner stays in lockstep with the developer's local checkout
#      under ~/fw_handlers — no rebuild needed for handler edits.
#   2. One image works for all 8+ examples — compose just picks the
#      name via env var. New examples added to the registry need no
#      Dockerfile change.

FROM python:3.12-slim

WORKDIR /app

# Build-time system packages.  osmium-tool is needed by the OSM
# example pipelines; git is needed only if the entrypoint falls back
# to `git clone` for an example whose source dir isn't bind-mounted.
RUN apt-get update && apt-get install -y --no-install-recommends \
        osmium-tool \
        git \
        curl \
        ca-certificates \
    && rm -rf /var/lib/apt/lists/*

# tippecanoe — builds the vector tiles for osm.Tiles.BuildVectorTiles.
# It is NOT packaged in Debian apt, so build the pinned release from
# source, then drop the build toolchain (keeping only the runtime libs
# tippecanoe links: libsqlite3-0, zlib1g) to keep the image slim.
#
# This MUST live in the image, not be hand-installed in a container:
# the OSM runner is scaled to N replicas that race the same task list,
# so a tippecanoe missing from any replica makes tile-build tasks
# dead-letter when they happen to land there (pet-vs-cattle trap).
ARG TIPPECANOE_VERSION=2.53.0
RUN apt-get update \
    && apt-get install -y --no-install-recommends \
        build-essential libsqlite3-dev zlib1g-dev \
    && git clone --depth 1 --branch "${TIPPECANOE_VERSION}" \
        https://github.com/felt/tippecanoe.git /tmp/tippecanoe \
    && make -C /tmp/tippecanoe -j"$(nproc)" \
    && make -C /tmp/tippecanoe install \
    && rm -rf /tmp/tippecanoe \
    && apt-get purge -y build-essential libsqlite3-dev zlib1g-dev \
    && apt-get install -y --no-install-recommends libsqlite3-0 zlib1g \
    && apt-get autoremove -y \
    && rm -rf /var/lib/apt/lists/* \
    && tippecanoe --version

# pmtiles CLI — converts tippecanoe's .mbtiles output into the .pmtiles
# archives the MapLibre viewers Range-fetch (osm.viz.RenderTiledMap via
# osm.Tiles.BuildVectorTiles). Like tippecanoe it is NOT in Debian apt;
# without it BuildVectorTiles silently falls back to .mbtiles and the
# browser's PMTiles client cannot read the layer (routes/lines vanish).
# Same pet-vs-cattle reason it must be in the image, not hand-installed.
# Pinned prebuilt release from protomaps/go-pmtiles.
ARG PMTILES_VERSION=1.30.3
RUN ARCH="$(dpkg --print-architecture)" \
    && case "$ARCH" in \
         amd64) PM_ARCH=x86_64 ;; \
         arm64) PM_ARCH=arm64 ;; \
         *) echo "unsupported arch: $ARCH" >&2; exit 1 ;; \
       esac \
    && curl -fsSL -o /tmp/pmtiles.tar.gz \
        "https://github.com/protomaps/go-pmtiles/releases/download/v${PMTILES_VERSION}/go-pmtiles_${PMTILES_VERSION}_Linux_${PM_ARCH}.tar.gz" \
    && tar -xzf /tmp/pmtiles.tar.gz -C /usr/local/bin pmtiles \
    && rm /tmp/pmtiles.tar.gz \
    && chmod +x /usr/local/bin/pmtiles \
    && pmtiles version

# Install facetwork from the build context.  Optional extras commonly
# needed across examples (folium / pyshp / osm2geojson / requests)
# come along for free.
COPY pyproject.toml .
COPY facetwork/ ./facetwork/
RUN pip install --no-cache-dir -e ".[mongodb]" \
    && pip install --no-cache-dir requests pyshp folium osm2geojson

# Entrypoint installs the named example then starts the runner.
COPY docker/entrypoint-example-runner.sh /usr/local/bin/entrypoint.sh
RUN chmod +x /usr/local/bin/entrypoint.sh

ENV PYTHONUNBUFFERED=1
ENV AFL_HANDLERS_ROOT=/handlers

ENTRYPOINT ["/usr/local/bin/entrypoint.sh"]
