# AgentFlow Seed Service
FROM python:3.12-slim

WORKDIR /app

# Install dependencies
COPY pyproject.toml .
RUN pip install --no-cache-dir -e ".[mongodb]" || \
    pip install --no-cache-dir lark pymongo

# Copy application code. The package is `facetwork`, not `afl`; the
# earlier `./afl/` rename was a relic of the project's rename and
# broke imports like `from facetwork.runtime.mongo_store import ...`
# inside seed.py.
COPY facetwork/ ./facetwork/
COPY docker/seed/ ./seed/
COPY examples/ ./examples/

ENV PYTHONUNBUFFERED=1
CMD ["python", "/app/seed/seed.py"]
